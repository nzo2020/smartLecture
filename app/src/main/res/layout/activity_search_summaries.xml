<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Title Section -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:text="🔍 Search Summaries"
        android:textColor="#444444"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Lecturer Selection Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Lecturer:"
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />
    <!-- Styled Spinner Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="20dp"
        android:background="@android:drawable/edit_text"
        android:backgroundTint="#F5F5F5">
        <Spinner
            android:id="@+id/spinnerLecturer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:spinnerMode="dropdown"
            android:paddingHorizontal="8dp" />
    </FrameLayout>

    <!-- Title Search Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search by title:"
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:layout_marginHorizontal="4dp"/>

    <!-- Search Input -->
    <EditText
        android:id="@+id/etSearchByTitle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Type name or topic..."
        android:textColorHint="#999999"
        android:textColor="#444444"
        android:background="@android:drawable/edit_text"
        android:backgroundTint="#F5F5F5"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:textSize="16sp"
        android:inputType="text" />

    <!-- Results List -->
    <ListView
        android:id="@+id/lvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackHome"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🏠 Back to Home"
        android:textAllCaps="false"
        android:textColor="#444444"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp" />

</LinearLayout>