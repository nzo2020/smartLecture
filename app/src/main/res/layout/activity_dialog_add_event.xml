<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFE"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Details"
            android:textColor="#1C1B1F"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center_horizontal"/>

        <!-- Event Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:padding="8dp"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etEventName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Event Title"
                android:inputType="textCapWords"
                android:background="@null"
                android:padding="12dp"
                android:textSize="16sp"
                android:textColorHint="#79747E"/>
        </LinearLayout>

        <!-- Date and Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etEventDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Date"
                android:focusable="false"
                android:clickable="true"
                android:background="@android:color/white"
                android:padding="16dp"
                android:layout_marginEnd="6dp"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/etEventTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Time"
                android:focusable="false"
                android:clickable="true"
                android:background="@android:color/white"
                android:padding="16dp"
                android:layout_marginStart="6dp"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Location -->
        <EditText
            android:id="@+id/etEventLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Location / Venue"
            android:inputType="textPostalAddress"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:textSize="16sp"/>

        <!-- Description -->
        <EditText
            android:id="@+id/etEventDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Describe the event..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:minLines="4"
            android:background="@android:color/white"
            android:padding="16dp"
            android:textSize="16sp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>