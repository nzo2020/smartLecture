<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- כותרת עליונה -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="Lesson Recording"
            android:textColor="#1C1B1F"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Record, summarize and share"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="32dp"/>

        <!-- שדה שם המורה -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Teacher's Name"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#DDDDDD"
            app:startIconDrawable="@android:drawable/ic_menu_edit">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTeacherName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="#444444" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- סטטוס: זמן ומיקום (עיצוב נקי) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F8F9FA"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvRecordingTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏱ 00:00"
                android:textColor="#D81B60"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📍 Location Off"
                android:gravity="end"
                android:textColor="#757575"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- כפתורי שליטה בהקלטה -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartRecording"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Start"
                android:textAllCaps="false"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_media_play" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStopRecording"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Stop"
                android:textAllCaps="false"
                app:backgroundTint="#F44336"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_media_pause" />
        </LinearLayout>

        <!-- אזור הסיכום -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lesson Summary"
            android:textStyle="bold"
            android:textColor="#444444"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvLessonSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:padding="16dp"
                android:text="Summary will appear here after recording..."
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- הגדרות פרטיות (סוויץ') -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Make this lesson public"
                android:textColor="#444444"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swPublicAccess"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FF4081"
                app:trackTint="#FFB2D1" />
        </LinearLayout>

        <!-- כפתורי פעולה סופיים -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSummary"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Save &amp; Create New"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FF4081"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackHome"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="#444444"
            app:cornerRadius="12dp"
            app:strokeColor="#DDDDDD" />

    </LinearLayout>
</ScrollView>